{
  "expo": {
    "name": "Vyb",
    "slug": "vyb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "vyb",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xyryc.vyb",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "appleTeamId": "3KZ7XWRYB7"
    },
    "android": {
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#00070f",
        "foregroundImage": "./assets/images/android-adaptive-foreground.png",
        "monochromeImage": "./assets/images/android-adaptive-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "package": "com.xyryc.vyb",
      "permissions": [
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#00070f",
          "dark": {
            "backgroundColor": "#00070f"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-media-control",
        {
          "enableBackgroundAudio": true,
          "audioSessionCategory": "playback",
          "notificationIcon": "./assets/images/notification_icon.png"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
