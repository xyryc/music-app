{
  "expo": {
    "name": "Vyb",
    "slug": "vyb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "vyb",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    },
    "notification": {
      "icon": "./assets/images/notification_icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xyryc.vyb",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      },
      "appleTeamId": "3KZ7XWRYB7"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00070f",
        "foregroundImage": "./assets/images/android-adaptive-foreground.png",
        "monochromeImage": "./assets/images/android-adaptive-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "package": "com.xyryc.vyb",
      "permissions": [
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-media-control",
        {
          "enableBackgroundAudio": true,
          "audioSessionCategory": "playback",
          "notificationIcon": "./assets/images/notification_icon.png"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
